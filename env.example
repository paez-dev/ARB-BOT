# ARB-BOT - Variables de Entorno
# Copia este archivo a .env y completa con tus valores

# ============================================
# CONFIGURACIÓN DE MODELOS DE IA
# ============================================
# Opción 1: Modelo Local (gratis, pero puede fallar)
# Opción 2: API Gratuita (recomendado - mejor calidad)

# Usar API en lugar de modelo local (true/false)
# RECOMENDADO: true (usa APIs gratuitas de modelos avanzados)
USE_API_MODEL=false

# Proveedor de API (huggingface, groq, gemini)
# - huggingface: Gratis, muchos modelos, puede ser lento
# - groq: Gratis, MUY rápido, modelos Llama (RECOMENDADO)
# - gemini: Gratis, buena calidad, límites generosos
API_PROVIDER=huggingface

# Modelo específico (opcional, usa defaults si está vacío)
# Hugging Face: microsoft/DialoGPT-medium, meta-llama/Llama-3.1-8B-Instruct, etc.
# Groq: llama-3.1-8b-instant, llama-3.1-70b-versatile, mixtral-8x7b-32768
# Gemini: gemini-pro, gemini-pro-vision
API_MODEL_NAME=

# API Keys (Obtén una gratis en los links)
# Hugging Face: https://huggingface.co/settings/tokens (gratis)
HUGGINGFACE_API_KEY=

# Groq: https://console.groq.com/keys (gratis, muy rápido) - RECOMENDADO
GROQ_API_KEY=

# Google Gemini: https://makersuite.google.com/app/apikey (gratis)
GEMINI_API_KEY=

# OpenAI (Opcional - solo si quieres usar OpenAI, NO es gratis)
OPENAI_API_KEY=

# Configuración de Flask
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=change-this-to-a-random-secret-key-in-production

# Contraseña de Administración (CAMBIAR EN PRODUCCIÓN)
ADMIN_PASSWORD=admin123

# Supabase Storage (Opcional - para persistencia de documentos)
# Obtén estos valores en: https://supabase.com/dashboard/project/_/settings/api
# SUPABASE_URL=https://tu-proyecto.supabase.co
# SUPABASE_KEY=tu-anon-key-aqui
# SUPABASE_BUCKET=documents

# Warmup Automático (deshabilitado por defecto en producción gratuita)
# AUTO_WARMUP_ENABLED=false

# Configuración de Base de Datos
DATABASE_URL=sqlite:///arbot.db

# Configuración de Modelos
# RECOMENDADO:
# - microsoft/DialoGPT-medium: Modelo conversacional de mejor calidad (RECOMENDADO - funciona muy bien)
# - microsoft/DialoGPT-small: Más ligero pero menor calidad
# - gpt2: Más estable pero principalmente en inglés
# - facebook/blenderbot-small-90M: Entrenado específicamente para chatbots
# 
# NOTA: PlanTL-GOB-ES/gpt2-base-bne no está disponible actualmente
DEFAULT_MODEL=microsoft/DialoGPT-medium
MAX_TOKENS=150
TEMPERATURE=0.7

# Precarga de modelos (ajusta según tu plan en Railway)
PRELOAD_MODELS_ON_STARTUP=true
PRELOAD_RAG_ON_STARTUP=true

