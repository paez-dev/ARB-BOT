# ARB-BOT - Variables de Entorno
# Copia este archivo a .env y completa con tus valores

# API Keys (Opcionales - el sistema funciona sin ellas en modo demo)
# Hugging Face: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=

# OpenAI (Opcional - solo si quieres usar OpenAI en lugar de Hugging Face)
OPENAI_API_KEY=

# Configuración de Flask
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=change-this-to-a-random-secret-key-in-production

# Configuración de Base de Datos
DATABASE_URL=sqlite:///arbot.db

# Configuración de Modelos
DEFAULT_MODEL=distilgpt2
MAX_TOKENS=150
TEMPERATURE=0.7

